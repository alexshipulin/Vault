rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function incomingDocumentOwnedByUser() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function existingDocumentOwnedByUser() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsPathUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /scan_results/{scanId} {
      allow create: if incomingDocumentOwnedByUser();
      allow read, delete: if existingDocumentOwnedByUser();
      allow update: if existingDocumentOwnedByUser() && incomingDocumentOwnedByUser();
    }

    match /antique_auctions/{auctionId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /user_collections/{userId} {
      allow read, write: if ownsPathUser(userId);

      match /items/{itemId} {
        allow read, write: if ownsPathUser(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
