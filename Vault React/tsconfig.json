{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@src/*": [
        "./src/*"
      ]
    },
    "types": [
      "jest",
      "@testing-library/jest-native"
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "constants/**/*.ts",
    "app.config.ts"
  ],
  "exclude": [
    "lib/**/*",
    "node_modules",
    "dist"
  ]
}
