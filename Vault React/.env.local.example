# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Gemini AI
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# Live analysis defaults
EXPO_PUBLIC_VAULT_ENVIRONMENT=production
EXPO_PUBLIC_VAULT_REMOTE_BACKEND=true
EXPO_PUBLIC_VAULT_FAST_PROCESSING=false
EXPO_PUBLIC_VAULT_SEED_DATA=false
EXPO_PUBLIC_VAULT_SKIP_ONBOARDING=true

# Switch to mock/demo mode if you want deterministic local results:
# EXPO_PUBLIC_VAULT_ENVIRONMENT=mock
# EXPO_PUBLIC_VAULT_REMOTE_BACKEND=false
# EXPO_PUBLIC_VAULT_FAST_PROCESSING=true
# EXPO_PUBLIC_VAULT_SEED_DATA=true

# Optional local development flags
EXPO_PUBLIC_VAULT_CLEAR_DATA=false
EXPO_PUBLIC_VAULT_FORCE_MOCK_CAMERA=false
EXPO_PUBLIC_VAULT_DEBUG_SINK_URL=
